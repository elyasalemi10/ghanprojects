# PDCON Lending Platform - Environment Variables
# Copy this to .env and fill in actual values. NEVER commit .env to git.

# Database connection string
# PostgreSQL example: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pdcon_lending?schema=public"

# NextAuth
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Optional - file uploads (for documents)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="ap-southeast-2"
# AWS_S3_BUCKET=""

# Optional - email for password reset (e.g. Resend, SendGrid, AWS SES)
# EMAIL_FROM="noreply@pdcon.com.au"
# RESEND_API_KEY=""
